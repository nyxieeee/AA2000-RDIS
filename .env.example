# Groq API Key — free at https://console.groq.com (no credit card required)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Backend base URL used in production (dev uses Vite proxy /api)
VITE_API_BASE_URL=https://your-backend-host.example

# Toggle legacy /documents CRUD API integration
VITE_USE_DOCUMENTS_API=false

# Launch-token auth (URL bootstrap)
VITE_VERIFY_LAUNCH_URL=https://your-auth-host/security/verify-launch?__launch={token}
VITE_VERIFY_SESSION_URL=https://your-auth-host/security/session/{token}
VITE_AUTH_API_BASE_URLS=https://your-auth-host,https://fallback-auth-host
VITE_LAUNCH_AES_KEY=your_portal_aes_key_hex_or_base64
VITE_LAUNCH_TOKEN_SECRET=your_legacy_secret
VITE_AUTH_STRICT_ROUTES=false
VITE_AUTH_DEBUG=false
